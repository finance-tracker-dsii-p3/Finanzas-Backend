# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/proyecto_financiero_db
DB_NAME=proyecto_financiero_db
DB_USER=postgres  
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Configuración Django
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=proyecto_financiero.settings.development

# Configuración específica financiera
DEFAULT_CURRENCY=COP
GMF_RATE=0.004
DEFAULT_IVA_RATE=0.19

# Render.com (para producción)
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com